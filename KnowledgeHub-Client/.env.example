# Path to the KnowledgeVault content folder, relative to this app (KnowledgeHub-Client).
# Optional — defaults to ../KnowledgeVault (the sibling folder in this monorepo).
VAULT_DIR=../KnowledgeVault

# ─── Authoring (local only) ──────────────────────────────────────────────────
# In-app authoring (create/edit topics, Save = git commit + push) is ON by
# default in `next dev` and OFF in production builds. Set this to "true" to force
# it on in a non-dev environment. Leave it UNSET on Vercel — the deployed site
# must stay read-only (its filesystem is read-only and it has no git).
# KNOWLEDGEHUB_AUTHORING=true

# ─── Publish branch (optional) ───────────────────────────────────────────────
# Save (commit + push) targets this branch. Defaults to "development". You must
# be on this branch when you publish — KnowledgeHub refuses otherwise so content
# never lands on the wrong branch.
# KNOWLEDGEHUB_PUBLISH_BRANCH=development
